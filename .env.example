# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real credentials.

# Capital & risk overrides (optional — config.py defaults apply if omitted)
# INITIAL_BALANCE=10000
# MAX_POSITION_PCT=0.10
# STOP_LOSS_PCT=0.015
# TAKE_PROFIT_PCT=0.030
# MAX_DAILY_LOSS_PCT=0.05
# SL_TP_CHECK_SECS=5

# Dynamic universe (top movers by 4h ATR + daily volume whitelist)
# USE_DYNAMIC_UNIVERSE=true
# UNIVERSE_ACTIVE_COUNT=4
# UNIVERSE_RESCAN_HOURS=4
# UNIVERSE_MIN_QUOTE_VOLUME_USDT=5000000

# Portfolio risk (across all bots)
# MAX_PORTFOLIO_POSITIONS=3
# MAX_POSITIONS_PER_BOT=1

# MACD entry filters (relaxed defaults)
# MACD_VOL_MULT=1.5
# MACD_ADX_MIN=18
# MACD_RSI_MIN=40
# MACD_RSI_MAX=78
# MACD_REQUIRE_HIST_GROWING=false
# MACD_MIN_ATR_PCT=0.004

# Exchange (optional)
# EXCHANGE_ID=bybit

# Web dashboard — set to require X-API-Key on /api/* routes (leave empty for local dev)
# DASHBOARD_API_KEY=

# Telegram notifications (optional)
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# Bybit API credentials (required for live trading — NOT needed for paper mode)
# BYBIT_API_KEY=
# BYBIT_API_SECRET=
